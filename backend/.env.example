# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/student-os?retryWrites=true&w=majority
MONGODB_DB_NAME=student-os

# JWT Secrets (use strong random strings in production)
JWT_ACCESS_SECRET=your-super-secure-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-super-secure-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookie Configuration
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=strict
COOKIE_MAX_AGE=604800000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# Account Security
BCRYPT_ROUNDS=12
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION_MS=1800000
PASSWORD_MIN_LENGTH=8

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=your-ai-service-secret-key
AI_SERVICE_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Features
ENABLE_CSRF_PROTECTION=true
ENABLE_HELMET_PROTECTION=true

# AI Service Configuration
NODE_ENV=development
PORT=8000

# API Security
AI_SERVICE_SECRET=your-ai-service-secret-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Model Configuration
MODEL_VERSION=2.0.0
CONFIDENCE_THRESHOLD=0.7

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Timeouts
REQUEST_TIMEOUT=30
MODEL_PREDICTION_TIMEOUT=5
